{
  "expo": {
    "name": "Loqlearn",
    "slug": "loqlearn",
    "version": "2.0.2",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#4338CA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.loqlearn.app",
      "buildNumber": "54",
      "minimumOsVersion": "16.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Unloq uses the camera to let you capture notes and documents for your study sessions.",
        "NSMicrophoneUsageDescription": "Unloq uses the microphone to record audio when capturing study material.",
        "NSPhotoLibraryUsageDescription": "Unloq accesses your photo library so you can upload images as study material."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6366F1",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.loqlearn.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "loqlearn",
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "./plugins/withFamilyControls",
      "expo-apple-authentication",
      "expo-web-browser",
      ["expo-speech-recognition", { "microphonePermission": "Allow Unloq to listen while you teach concepts back to your crew." }]
    ],
    "extra": {
      "eas": {
        "projectId": "40156d1d-55bf-4586-aa26-ed9ea0cb89d7"
      }
    }
  }
}
